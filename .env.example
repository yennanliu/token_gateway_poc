# Copy to .env and fill in. All values have sane defaults for local dev.

# Database (default: local SQLite file). For Postgres:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gateway
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# Upstream provider keys (the REAL keys the gateway injects)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Console / admin API token
ADMIN_TOKEN=dev-admin-token

# Rate limiting (0 = unlimited). Set REDIS_URL to share limits across instances;
# leave blank for the in-memory token bucket.
DEFAULT_RPM_LIMIT=0
REDIS_URL=

# Cross-provider translation (OpenAI-format client -> claude-* model)
ENABLE_TRANSLATION=false

# Upstream retries
MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=0.2

# Payments. Leave STRIPE_SECRET_KEY blank for immediate mock top-ups.
# With it set, /admin/.../checkout creates a real Checkout Session and credits
# are applied when the signed /admin/webhooks/stripe event arrives.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8000/?topup=success
STRIPE_CANCEL_URL=http://localhost:8000/?topup=cancel
